{
  "manifest_version": 3,
  "name": "Netflix Loop",
  "version": "1.0.0",
  "description": "Loop a specified time range on Netflix. Useful for language learning, music, dance practice, etc.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Netflix Loop — open a video to use the panel",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://www.netflix.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://www.netflix.com/*"],
      "js": ["page.js"],
      "world": "MAIN",
      "run_at": "document_idle"
    }
  ],
  "permissions": ["storage"],
  "host_permissions": ["*://www.netflix.com/*"]
}
